#!/usr/bin/env bash
# spinner-theme — switch Claude Code's spinner words between themed sets.
# Safe by design: backs up settings.json before any change, edits ONLY the
# spinnerVerbs key (everything else is preserved via jq), and validates after.
#
#   spinner-theme list                list themes + show which is active
#   spinner-theme set <name>          apply a theme (plain words)
#   spinner-theme set <name> --emoji  apply with the theme's default emoji
#   spinner-theme set <name> --emoji 🦄   apply with an emoji you choose
#   spinner-theme current             print the active theme + its verbs
#   spinner-theme mode <m>            set mode of active theme: replace | append
#   spinner-theme off                 remove spinnerVerbs (back to Claude defaults)
#   spinner-theme restore             roll back to the last backup
#
# Note: emoji render in most modern terminals; the Scotland flag 🏴 (subdivision
# sequence) is unreliable in terminal fonts. Unicorn/castle/football render fine.
#
# Settings file defaults to ~/.claude/settings.json (override with CLAUDE_SETTINGS).
set -euo pipefail

SETTINGS="${CLAUDE_SETTINGS:-$HOME/.claude/settings.json}"
BACKUP="$SETTINGS.bak.spinner"
# themes/ sits next to this script's parent (repo root)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
THEMES_DIR="${SPINNER_THEMES_DIR:-$SCRIPT_DIR/../themes}"

command -v jq >/dev/null || { echo "error: jq is required (brew install jq)"; exit 1; }
[ -f "$SETTINGS" ] || { echo "error: settings file not found: $SETTINGS"; exit 1; }

theme_file() { echo "$THEMES_DIR/$1.json"; }

list_themes() {
  echo "Available themes (active marked *):"
  local active; active="$(current_name || true)"
  for f in "$THEMES_DIR"/*.json; do
    local name n; name="$(basename "$f" .json)"; n="$(jq '.verbs | length' "$f")"
    local mark="  "; [ "$name" = "$active" ] && mark=" *"
    printf "%s %-20s %3s words\n" "$mark" "$name" "$n"
  done
}

# Print the name of the theme whose verb set matches the active one. Tolerant of
# an emoji garnish: a leading non-letter run + space is stripped before comparing.
current_name() {
  jq -e '.spinnerVerbs.verbs' "$SETTINGS" >/dev/null 2>&1 || { echo ""; return 1; }
  local strip='map(sub("^[^A-Za-z]+\\s+";"")) | sort'
  local cur; cur="$(jq -c ".spinnerVerbs.verbs | $strip" "$SETTINGS")"
  for f in "$THEMES_DIR"/*.json; do
    if [ "$cur" = "$(jq -c ".verbs | $strip" "$f")" ]; then basename "$f" .json; return 0; fi
  done
  echo "custom"; return 0
}

backup() { cp "$SETTINGS" "$BACKUP"; }

write_settings() { # stdin = new json
  local tmp; tmp="$(mktemp)"
  cat > "$tmp"
  jq empty "$tmp" || { echo "error: produced invalid JSON, aborting"; rm -f "$tmp"; exit 1; }
  mv "$tmp" "$SETTINGS"
}

case "${1:-}" in
  list|ls|"") list_themes ;;

  current)
    name="$(current_name || true)"
    if [ -z "$name" ]; then echo "spinnerVerbs not set (using Claude defaults)"; exit 0; fi
    echo "Active theme: $name"
    jq -r '.spinnerVerbs.mode as $m | ".mode: \($m)"' "$SETTINGS"
    jq -r '.spinnerVerbs.verbs[]' "$SETTINGS" | sed 's/^/  /'
    ;;

  set)
    name="${2:?usage: spinner-theme set <name> [--emoji [CHAR]]}"
    f="$(theme_file "$name")"
    [ -f "$f" ] || { echo "error: no such theme '$name'"; list_themes; exit 1; }
    emoji=""
    if [ "${3:-}" = "--emoji" ]; then
      emoji="${4:-$(jq -r '.emoji // "🦄"' "$f")}"
    fi
    backup
    if [ -n "$emoji" ]; then
      jq --slurpfile t "$f" --arg e "$emoji" \
        '.spinnerVerbs = {mode: $t[0].mode, verbs: ($t[0].verbs | map($e + " " + .))}' \
        "$SETTINGS" | write_settings
      echo "Set spinner theme to '$name' with $emoji ($(jq '.verbs|length' "$f") words). Restart Claude Code to see it."
    else
      jq --slurpfile t "$f" \
        '.spinnerVerbs = {mode: $t[0].mode, verbs: $t[0].verbs}' \
        "$SETTINGS" | write_settings
      echo "Set spinner theme to '$name' ($(jq '.verbs|length' "$f") words). Restart Claude Code to see it."
    fi
    ;;

  mode)
    m="${2:?usage: spinner-theme mode <replace|append>}"
    [ "$m" = "replace" ] || [ "$m" = "append" ] || { echo "error: mode must be replace or append"; exit 1; }
    jq -e '.spinnerVerbs' "$SETTINGS" >/dev/null 2>&1 || { echo "error: no spinnerVerbs set; run 'spinner-theme set <name>' first"; exit 1; }
    backup
    jq --arg m "$m" '.spinnerVerbs.mode = $m' "$SETTINGS" | write_settings
    echo "Set mode to '$m'. Restart Claude Code to see it."
    ;;

  off|default)
    backup
    jq 'del(.spinnerVerbs)' "$SETTINGS" | write_settings
    echo "Removed spinnerVerbs — back to Claude's default words. Restart Claude Code."
    ;;

  restore)
    [ -f "$BACKUP" ] || { echo "error: no backup found at $BACKUP"; exit 1; }
    cp "$BACKUP" "$SETTINGS"
    echo "Restored settings from $BACKUP."
    ;;

  -h|--help|help)
    sed -n '2,18p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
    ;;

  *)
    echo "unknown command: $1"; echo; sed -n '2,18p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'; exit 1
    ;;
esac
